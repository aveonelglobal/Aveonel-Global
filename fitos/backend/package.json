{
  "name": "fitos-backend",
  "version": "1.0.0",
  "description": "FitOS - Personal AI Health Operating System backend API",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
