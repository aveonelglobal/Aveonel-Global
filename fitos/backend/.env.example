# Server
PORT=4000
NODE_ENV=development

# Supabase (https://app.supabase.com/project/_/settings/api)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Shared secret n8n/webhooks must send as `x-fitos-webhook-secret` header
FITOS_WEBHOOK_SECRET=change-me

# AI Planner Core - optional. If unset, the planner falls back to its
# deterministic rule-based engine (fully functional without any LLM key).
ANTHROPIC_API_KEY=

# Telegram bot (used by /reminders/dispatch to push messages directly, optional
# if reminders are only consumed by n8n's own Telegram node)
TELEGRAM_BOT_TOKEN=
